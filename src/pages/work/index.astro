---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import WorkCard from "@/components/work/WorkCard.astro";
// content
import { getCollection } from "astro:content";
const allWork = await getCollection("work");
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pb-12 pt-48">
      <div
        class="mx-auto text-center"
        data-aos="fade-down"
        data-aos-duration="3000"
      >
        <Text tag="h1" variant="displayXL" class="text-white font-display">
          Selected work.<span class="md:block text-base-400">
            We are proud of this ones.</span
          >
        </Text>
        <Text tag="p" variant="textBase" class="mt-4 text-base-300"
          >A design agency without a twist</Text
        >
      </div>
      <ul
        role="list"
        class="grid grid-cols-1 gap-4 mt-24 md:grid-cols-2 lg:grid-cols-3"
      >
        {allWork.map((post) => <WorkCard post={post} />)}
      </ul>
    </Wrapper>
  </section>
</BaseLayout>
