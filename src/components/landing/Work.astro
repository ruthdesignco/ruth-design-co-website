---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const work = [
  {
    id: "walmart",
    // visualLabel: shown inside the card image
    visualLabel: "Enterprise AI platform development & governance",
    outcome: "Built the foundation for how Walmart merchants deploy AI agents.",
    description:
      "We led the design of AI patterns and frameworks for Walmart's merchandising and supplier organization. The work became the foundation for the governance frameworks, guardrails, and protocol infrastructure that now allow individual employees to spin up and deploy agents at scale across one of the largest retail operations in the world.",
  },
  {
    id: "medtronic",
    visualLabel: "McKinsey & Company / Medtronic — Surgical platform redesign",
    outcome: "Unified the clinical workflow for a global MedTech leader's surgical planning platform.",
    description:
      "Fragmented communication and disjointed data systems were creating friction at every step of Medtronic's Surgeon Hub platform. We led all design efforts — research across 19 surgeons and lab engineers, journey mapping, and high-fidelity prototyping — delivering a mobile-first redesign that reduced cognitive load and established the UX architecture for platform scaling.",
    caseStudyHref: "https://drive.google.com/file/d/1T85iEe-A5JBrOwEX9lAPPo9cRjhIzvWY/view?usp=drive_link",
  },
  {
    id: "teck",
    visualLabel: "McKinsey & Company / Teck Resources — Generative AI tool for industrial operations",
    outcome: "An AI strategy and toolset for mine equipment maintenance workers.",
    description:
      "We designed a conversational AI copilot for maintenance workers at a large-scale mining site, built to reduce equipment downtime and eliminate fragmented diagnostic workflows. Embedded as design lead on a five-week engagement, we owned research, journey mapping, and interface prototyping — from shop floor to boardroom presentation.",
    caseStudyHref: "/Case%20Studies/Case%20Studies%20-%20Teck%20Mining.pdf",
  },
];
---

<section id="work" class="bg-[#0a0a09] scroll-mt-24">
  <Wrapper variant="standard" class="py-32">
    <div data-aos="fade-up" data-aos-duration="2000">
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        Selected Work
      </p>
      <Text tag="h2" variant="displayMD" class="text-[#f0ede8] font-display">
        Where we've done this before.
      </Text>
      <Text tag="p" variant="textLG" class="font-sans font-light text-[#a8a89f] leading-relaxed max-w-2xl mt-6">
        Enterprise-grade AI and design judgment, applied to the challenges scaling companies actually face.
      </Text>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
      {work.map((entry) => (
        <div
          class="bg-[#111110] rounded overflow-hidden flex flex-col"
          data-aos="fade-up"
          data-aos-duration="2000"
        >

          <!-- Card image area: logo + engagement label -->
          <div
            class="w-full aspect-[4/3] bg-[#111110] border-b border-white/[0.06] flex flex-col items-center justify-center"
            style="padding: 10%;"
          >

            <!-- Logo — swap viewBox + inner paths when real assets are supplied -->
            {entry.id === "walmart" && (
              <svg
                viewBox="0 0 200 40"
                fill="currentColor"
                xmlns="http://www.w3.org/2000/svg"
                style="height: 40px; width: auto; max-width: 100%; flex-shrink: 0; color: #ffffff;"
                aria-label="Walmart"
              >
                <text x="100" y="30" text-anchor="middle" font-family="sans-serif" font-size="26" font-weight="700" letter-spacing="5" fill="currentColor">WALMART</text>
              </svg>
            )}

            {entry.id === "medtronic" && (
              <svg
                viewBox="0 0 240 40"
                fill="currentColor"
                xmlns="http://www.w3.org/2000/svg"
                style="height: 40px; width: auto; max-width: 100%; flex-shrink: 0; color: #ffffff;"
                aria-label="Medtronic"
              >
                <text x="120" y="30" text-anchor="middle" font-family="sans-serif" font-size="24" font-weight="700" letter-spacing="4" fill="currentColor">MEDTRONIC</text>
              </svg>
            )}

            {entry.id === "teck" && (
              <svg
                viewBox="0 0 100 40"
                fill="currentColor"
                xmlns="http://www.w3.org/2000/svg"
                style="height: 40px; width: auto; max-width: 100%; flex-shrink: 0; color: #ffffff;"
                aria-label="Teck Resources"
              >
                <text x="50" y="30" text-anchor="middle" font-family="sans-serif" font-size="28" font-weight="700" letter-spacing="5" fill="currentColor">TECK</text>
              </svg>
            )}

            <!-- Engagement type label — same styling as former below-image metadata, accent-500 at full opacity -->
            <!-- min-h-[5rem] at md reserves space for up to 4 wrapped lines, aligning labels across all three cards -->
            <div class="mt-8 w-full flex items-start justify-center md:min-h-[5rem]">
              <p class="font-sans text-xs uppercase tracking-widest text-base-600 text-center leading-relaxed">
                {entry.visualLabel}
              </p>
            </div>

          </div>

          <!-- Card body: headline + description only -->
          <div class="p-8 flex flex-col flex-1">
            <Text
              tag="h3"
              variant="displaySM"
              class="font-display text-[#f0ede8] leading-snug mb-4"
            >
              {entry.outcome}
            </Text>
            <Text
              tag="p"
              variant="textBase"
              class="font-sans font-light text-[#a8a89f] leading-relaxed flex-1"
            >
              {entry.description}
            </Text>
            {entry.caseStudyHref && (
              <a
                href={entry.caseStudyHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block mt-6 font-sans text-sm text-accent-500 hover:underline"
              >
                View case study →
              </a>
            )}
          </div>

        </div>
      ))}
    </div>
  </Wrapper>
</section>
