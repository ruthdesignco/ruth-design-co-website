---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const services = [
  {
    number: "01",
    name: "AI Clarity Audit",
    description:
      "A structured, time-boxed engagement to map your highest-leverage AI opportunities and deliver a prioritized roadmap. The entry point for most engagements.",
  },
  {
    number: "02",
    name: "Design DNA & Executive Leadership",
    description:
      "We establish the design foundation — principles, visual language, and system logic — that makes every touchpoint feel like a single, premium ecosystem. Available as a defined engagement or on a fractional basis.",
  },
  {
    number: "03",
    name: "Product Strategy & Build",
    description:
      "We lead the design and build of any new product or feature, from the top — overseeing and reviewing the entire process with decades of design and technology experience and judgment.",
  },
  {
    number: "04",
    name: "AI Workflow Design",
    description:
      "Custom-fit tools, workflow automations, and agent deployments built directly into your operations — not bolted on after the fact.",
  },
];
---

<section id="services" class="bg-[#111110] scroll-mt-24">
  <Wrapper variant="standard" class="py-24">
    <div data-aos="fade-up" data-aos-duration="2000">
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        Services
      </p>
      <Text tag="h2" variant="displayMD" class="text-[#f0ede8] font-display">
        One partner, embedded and ongoing.
      </Text>
      <Text
        tag="p"
        variant="textLG"
        class="font-sans font-light text-[#a8a89f] leading-relaxed max-w-2xl mt-6"
      >
        The shape of every engagement is formed around the business and its unique problems.
      </Text>
    </div>

    <div class="mt-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          services.map((service) => (
            <div
              class="bg-[#222220] rounded p-8"
              data-aos="fade-up"
              data-aos-duration="2000"
            >
              <p class="text-xs font-sans font-normal text-base-600 tracking-widest mb-6">
                {service.number}
              </p>
              <Text
                tag="h3"
                variant="displaySM"
                class="font-display text-[#f0ede8] leading-snug mb-4"
              >
                {service.name}
              </Text>
              <Text
                tag="p"
                variant="textBase"
                class="font-sans font-light text-[#a8a89f] leading-relaxed"
              >
                {service.description}
              </Text>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
