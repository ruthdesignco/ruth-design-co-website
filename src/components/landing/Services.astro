---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const engagements = [
  {
    number: "01",
    name: "Clarity",
    heading: "See where AI actually creates leverage.",
    body: "A focused diagnostic engagement — where AI creates real leverage versus where it's hype, mapped to a clear decision about what to build and what to ignore. The low-risk way to experience the thinking before committing to more. Most engagements start here.",
  },
  {
    number: "02",
    name: "Vantage",
    heading: "The full engagement including strategy and execution.",
    body: "Senior AI and design leadership with hands-on execution — diagnosis, workflow design, and the build itself, delivered on a defined engagement. The leadership a full-time CDO brings, working in your business now instead of after a six-month hire.",
  },
  {
    number: "03",
    name: "Partnership",
    heading: "Ongoing leadership after the build ships.",
    body: "For founders who want a senior design and AI partner on a standing basis once the core work is done. Continued strategic leadership as your company and its AI footprint keep growing — without a permanent executive hire.",
  },
];
---

<section id="services" class="bg-[#111110] scroll-mt-24">
  <Wrapper variant="standard" class="py-24">
    <div data-aos="fade-up" data-aos-duration="2000">
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        How we work
      </p>
      <Text tag="h2" variant="displayMD" class="text-[#f0ede8] font-display">
        Structured engagements, run on a repeatable method.
      </Text>
      <Text
        tag="p"
        variant="textLG"
        class="font-sans font-light text-[#a8a89f] leading-relaxed max-w-2xl mt-6"
      >
        Most help comes split in two: strategists who hand you a deck and leave you to execute it, or builders who need someone else to tell them what to build. This is both in one place — the same senior judgment that diagnoses where AI creates real leverage also designs and ships the solution, so nothing gets lost in translation between the thinking and the doing.
      </Text>
    </div>

    <div class="mt-16 flex flex-col gap-6">
      {
        engagements.map((e) => (
          <div
            class="bg-[#222220] rounded p-8"
            data-aos="fade-up"
            data-aos-duration="2000"
          >
            <p class="text-xs font-sans font-normal text-base-600 tracking-widest mb-6">
              {e.number} — {e.name}
            </p>
            <Text
              tag="h3"
              variant="displaySM"
              class="font-display text-[#f0ede8] leading-snug mb-4"
            >
              {e.heading}
            </Text>
            <Text
              tag="p"
              variant="textBase"
              class="font-sans font-light text-[#a8a89f] leading-relaxed"
            >
              {e.body}
            </Text>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
