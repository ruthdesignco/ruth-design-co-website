---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const services = [
  {
    number: "01",
    name: "AI Analysis",
    description:
      "We use AI-powered tools to audit your digital presence, find where you're losing customers, and show you exactly how to fix it. This is how every engagement starts.",
  },
  {
    number: "02",
    name: "AI-Powered Lead Capture",
    description:
      "Never miss another customer. We set up AI agents that respond to calls and inquiries instantly — 24/7 — so every lead gets captured, qualified, and booked before they call your competitor.",
  },
  {
    number: "03",
    name: "Website & Conversion Optimization",
    description:
      "We fix the things on your website that are costing you customers right now. Clear calls-to-action, online booking, mobile optimization, and search visibility — the basics that drive revenue.",
  },
  {
    number: "04",
    name: "AI Agents & Workflow Automation",
    description:
      "Custom AI agents built into your daily operations. We design systems that handle lead follow-ups, scheduling, inventory, supplier coordination, and customer communication automatically — so your business runs even when you're not watching it.",
  },
];
---

<section id="services" class="bg-[#111110] scroll-mt-24">
  <Wrapper variant="standard" class="py-24">
    <div data-aos="fade-up" data-aos-duration="2000">
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        Services
      </p>
      <Text tag="h2" variant="displayMD" class="text-[#f0ede8] font-display">
        How we help local businesses grow.
      </Text>
      <Text
        tag="p"
        variant="textLG"
        class="font-sans font-light text-[#a8a89f] leading-relaxed max-w-2xl mt-6"
      >
        We bring Fortune 100 strategy and AI expertise to businesses that have never had access to it.
      </Text>
    </div>

    <div class="mt-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          services.map((service) => (
            <div
              class="bg-[#222220] rounded p-8"
              data-aos="fade-up"
              data-aos-duration="2000"
            >
              <p class="text-xs font-sans font-normal text-base-600 tracking-widest mb-6">
                {service.number}
              </p>
              <Text
                tag="h3"
                variant="displaySM"
                class="font-display text-[#f0ede8] leading-snug mb-4"
              >
                {service.name}
              </Text>
              <Text
                tag="p"
                variant="textBase"
                class="font-sans font-light text-[#a8a89f] leading-relaxed"
              >
                {service.description}
              </Text>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
