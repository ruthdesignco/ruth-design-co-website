---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section class="bg-[#0a0a09]">
  <Wrapper variant="standard" class="py-32">
    <div class="max-w-4xl mx-auto text-center" data-aos="fade-up" data-aos-duration="2000">
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        AI Clarity Audit
      </p>
      <Text tag="h2" variant="display2XL" class="text-[#f0ede8] font-display leading-snug">
        Ready to see what AI can do for your business?
      </Text>
      <Text tag="p" variant="textLG" class="font-sans font-light text-[#a8a89f] leading-relaxed mt-8">
        We'll run a free AI-powered analysis of your business and show you exactly where you're leaving money on the table — and how to fix it. No commitment, no cost. Just a 30-minute call to get started.
      </Text>
      <div class="flex justify-center mt-10">
        <Button href="https://calendly.com/tb-ruthdesign/30min" target="_blank" rel="noopener noreferrer" size="lg" variant="accent" class="shadow-none whitespace-nowrap">
          Schedule your free call →
        </Button>
      </div>
    </div>
  </Wrapper>
</section>
