---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section>
  <Wrapper variant="standard" class="pt-48 pb-32">
    <div
      class="max-w-3xl"
      data-aos="fade-down"
      data-aos-duration="1500"
    >
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        AI Strategy for Local Business
      </p>
      <Text tag="h1" variant="displayXL" class="text-[#f0ede8] font-display leading-tight">
        Your business is leaving money on the table. AI can fix that.
      </Text>
      <Text tag="p" variant="textLG" class="mt-6 text-base-400 font-sans font-light max-w-2xl leading-relaxed">
        Most small businesses are losing customers to slow response times, broken booking flows, and invisible search presence. We use AI to find the leaks and fix them fast.
      </Text>
      <div class="mt-10 w-fit">
        <Button href="/contact" size="lg" variant="accent" class="shadow-none"
          >Get Your Free AI Analysis →</Button
        >
      </div>
    </div>
  </Wrapper>
</section>
