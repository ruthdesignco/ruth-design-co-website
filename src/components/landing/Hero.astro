---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section>
  <Wrapper variant="standard" class="pt-48 pb-32">
    <div
      class="max-w-3xl"
      data-aos="fade-down"
      data-aos-duration="1500"
    >
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        Strategic AI &amp; design leadership
      </p>
      <Text tag="h1" variant="displayXL" class="text-[#f0ede8] font-display leading-tight">
        AI-native design leadership, embedded in your team.
      </Text>
      <Text tag="p" variant="textLG" class="mt-6 text-base-400 font-sans font-light max-w-2xl leading-relaxed">
        You get a senior partner who diagnoses where AI creates real leverage, designs and builds it, and leaves your team with repeatable patterns.
      </Text>
      <div class="mt-10 w-fit">
        <Button href="https://calendly.com/tb-ruthdesign/30min" target="_blank" rel="noopener noreferrer" size="lg" variant="accent" class="shadow-none"
          >Book a Clarity Conversation →</Button
        >
      </div>
    </div>
  </Wrapper>
</section>
