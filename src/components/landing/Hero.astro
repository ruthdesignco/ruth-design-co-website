---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section>
  <Wrapper variant="standard" class="pt-48 pb-32">
    <div
      class="max-w-3xl"
      data-aos="fade-down"
      data-aos-duration="1500"
    >
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        AI Strategy & Product Design
      </p>
      <Text tag="h1" variant="displayXL" class="text-[#f0ede8] font-display leading-tight">
        The design and AI leadership your team is missing.
      </Text>
      <Text tag="p" variant="textLG" class="mt-6 text-base-400 font-sans font-light max-w-2xl leading-relaxed">
        Technology is moving faster than most companies' ability to make sense of it. We work with founders and early-stage teams to move at the speed it actually requires.
      </Text>
      <div class="mt-10 w-fit">
        <Button href="/contact" size="lg" variant="accent" class="shadow-none"
          >Start with an AI Clarity Audit →</Button
        >
      </div>
    </div>
  </Wrapper>
</section>
