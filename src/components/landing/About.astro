---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section id="about" class="bg-[#111110] scroll-mt-24">
  <Wrapper variant="standard" class="py-32">

    <div class="grid grid-cols-1 md:grid-cols-5 md:gap-x-16 items-start" data-aos="fade-up" data-aos-duration="2000">

      <!-- Row 1 left: photo -->
      <div class="md:col-span-2">
        <div class="w-full aspect-[4/5] bg-[#1a1a18] border border-white/[0.08] rounded overflow-hidden">
          <img src="/Tyler.png" alt="Tyler Burton, Founder & Principal of Ruth Design Co." class="w-full h-full object-cover object-top" />
        </div>
      </div>

      <!-- Row 1 right: firm intro -->
      <div class="md:col-span-3 mt-12 md:mt-0">
        <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
          About
        </p>
        <Text tag="h2" variant="displayMD" class="text-[#f0ede8] font-display leading-snug">
          Fortune 100 expertise, built for local business.
        </Text>
        <Text tag="p" variant="textLG" class="font-sans font-normal text-[#a8a89f] leading-relaxed mt-8">
          Ruth Design Co. brings enterprise-level AI strategy and design to the businesses that need it most — local service companies, medical practices, law firms, and growing businesses across Arkansas, Oklahoma, Missouri, and Kansas. Every engagement is led personally by founder Tyler Burton.
        </Text>
      </div>

      <!-- Row 2: Tyler bio — spans full width of both columns above -->
      <div class="md:col-span-5 border-t border-white/[0.08] mt-12 pt-12">
        <Text tag="h3" variant="displaySM" class="font-display text-[#f0ede8] leading-snug">
          Tyler Burton, Founder & Principal
        </Text>
        <div class="mt-6 space-y-6">
          <Text tag="p" variant="textBase" class="font-sans font-light text-[#a8a89f] leading-relaxed">
            Tyler brings 12 years of product design experience across creative agencies, enterprise product organizations, and management consulting — with a track record of embedding in complex, high-stakes environments and delivering systems that actually ship.
          </Text>
          <Text tag="p" variant="textBase" class="font-sans font-light text-[#a8a89f] leading-relaxed">
            Before founding Ruth Design Co., he spent two years as a consultant with McKinsey & Company, where he learned to diagnose business problems before proposing design solutions. He led product design at Walmart, helping establish the agentic AI pattern library and governance frameworks now deployed across one of the largest retail AI ecosystems in the world.
          </Text>
          <Text tag="p" variant="textBase" class="font-sans font-light text-[#a8a89f] leading-relaxed">
            He founded Ruth Design Co. to bring that combination — consulting rigor, enterprise-grade design, and hands-on AI capability — directly to the local businesses that are ready to grow but don't know where to start with AI.
          </Text>
        </div>
      </div>

    </div>

  </Wrapper>
</section>
