---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Define the steps with their details
const steps = [
  {
    id: 1,
    title: "Submit",
    description: "Subscribe to a plan & request as many designs as you'd like.",
    aosDuration: "500",
  },
  {
    id: 2,
    title: "Refine",
    description: "Receive your design within a few business days on average.",
    aosDuration: "1000",
  },
  {
    id: 3,
    title: "Build",
    description: "We'll revise the designs until you're 100% satisfied.",
    aosDuration: "1500",
  },
  {
    id: 4,
    title: "Enjoy",
    description: "Enjoy your marvellous new website!",
    aosDuration: "2500",
  },
];
const features = [
  {
    title: "Totally async",
    description:
      "Don't like meetings? We don't either; so much so that we've outlawed them.",
  },
  {
    title: "Manage with Trello",
    description:
      "Manage your design board using Trello. View active, queued, and completed tasks.",
  },
  {
    title: "Invite unlimited team members",
    description:
      "Invite your entire team, so anyone can submit requests and track their progress.",
  },
];
---

<section class="overflow-hidden relative">
  <Wrapper variant="standard" class="py-24">
    <div data-aos="fade-up" data-aos-duration="2000">
      <Text
        tag="h2"
        variant="displayMD"
        class="text-white font-display text-center"
      >
        We did reinvented the <span class="md:block text-base-500"
          >wheel and also just design</span
        >
      </Text>
    </div>
    <div class="relative flex flex-wrap mt-24">
      <div class="absolute top-8 left-0 right-0 hidden lg:block h-[1px] -z-1">
        <div
          class="h-[1px] w-full bg-accent-300"
          data-aos="fade-left"
          data-aos-duration="3000"
        >
          &zwnj;
        </div>
      </div>
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4 relative">
        {
          steps.map((step) => (
            <div class="w-full pb-4 border-b border-base-800">
              <span
                data-aos="fade-down"
                data-aos-duration={step.aosDuration}
                class="flex items-center justify-center size-12 mb-5 lg:mb-16 text-accent-300 rounded-xl border bg-gradient-to-tr from-base-950 to-base-700 border-base-800 shadow-massive "
              >
                {step.id}
              </span>
              <div>
                <Text
                  tag="h3"
                  variant="textLG"
                  class="mt-12  font-medium leading-6 text-white"
                >
                  {step.title}
                </Text>
                <Text tag="p" variant="textBase" class="mt-4  text-base-400">
                  {step.description}
                </Text>
              </div>
            </div>
          ))
        }
      </div>
    </div>
    <div
      data-aos="fade-up"
      data-aos-duration="2000"
      class="text-center ring-1 ring-base-800 border bg-gradient-to-tr from-base-950 to-base-700 border-base-800 shadow-big h-full lg:col-span-full lg:p-20 mt-24 p-8 rounded-4xl relative"
    >
      <Text
        tag="h4"
        variant="displayMD"
        class="text-white font-display textbalance max-w-2xl mx-auto"
      >
        "Aubergine Studio are a rare breed of designers and developers they
        understands business needs."
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="text-base-300 mt-6 italic uppercase"
      >
        Gerard Depardieu
      </Text>
    </div>
    <div
      class="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-x-6 mt-24 lg:text-center"
    >
      {
        features.map((feature) => (
          <div class="pb-4 border-b border-base-800">
            <Text
              tag="h3"
              variant="textLG"
              class=" font-medium leading-6 text-white"
            >
              {feature.title}
            </Text>
            <Text tag="p" variant="textBase" class="mt-4 text-base-400">
              {feature.description}
            </Text>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
