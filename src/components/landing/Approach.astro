---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section id="approach" class="bg-[#111110]">
  <Wrapper variant="standard" class="pt-32 pb-24 scroll-mt-24">
    <div data-aos="fade-up" data-aos-duration="2000">
      <p class="text-xs font-sans font-normal uppercase tracking-widest text-accent-500 mb-6">
        Approach
      </p>
      <Text tag="h2" variant="displayMD" class="text-[#f0ede8] font-display">
        Design is moving upstream. We've always been there.
      </Text>
      <div class="max-w-2xl mt-6 space-y-6">
        <Text
          tag="p"
          variant="textLG"
          class="font-sans font-light text-base-400 leading-relaxed"
        >
          AI is changing where design happens. We've always worked there.
        </Text>
        <Text
          tag="p"
          variant="textLG"
          class="font-sans font-light text-base-400 leading-relaxed"
        >
          We don't sell a process. We solve your problem.
        </Text>
        <Text
          tag="p"
          variant="textLG"
          class="font-sans font-light text-base-400 leading-relaxed"
        >
          Every engagement starts the same way: we get close to your business before we touch your product. We study the workflows, follow the data, talk to the people running it. The diagnosis comes before the prescription.
        </Text>
      </div>
    </div>
  </Wrapper>
</section>
