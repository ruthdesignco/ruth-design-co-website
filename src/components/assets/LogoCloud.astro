---
const opacity = "0.6";
const fill = "#f0ede8";
---

<section class="w-full overflow-hidden border-y border-white/[0.08] py-8">
  <div class="marquee-track flex items-center">

    {[0, 1, 2].map((i) => (
      <div class="flex items-center shrink-0" aria-hidden={i > 0 ? "true" : undefined}>

        {/* Walmart */}
        <div class="px-12">
          <svg height="22" viewBox="0 0 120 22" fill="none" xmlns="http://www.w3.org/2000/svg" style={`opacity:${opacity}`}>
            <g fill={fill}>
              <!-- Spark: 6 petals -->
              <ellipse cx="11" cy="11" rx="2.2" ry="5.5" transform="rotate(0 11 11)" />
              <ellipse cx="11" cy="11" rx="2.2" ry="5.5" transform="rotate(60 11 11)" />
              <ellipse cx="11" cy="11" rx="2.2" ry="5.5" transform="rotate(120 11 11)" />
              <ellipse cx="11" cy="11" rx="2.2" ry="5.5" transform="rotate(180 11 11)" />
              <ellipse cx="11" cy="11" rx="2.2" ry="5.5" transform="rotate(240 11 11)" />
              <ellipse cx="11" cy="11" rx="2.2" ry="5.5" transform="rotate(300 11 11)" />
            </g>
            <text x="30" y="16" font-family="sans-serif" font-size="15" font-weight="700" fill={fill} letter-spacing="0.3">Walmart</text>
          </svg>
        </div>

        {/* NFL */}
        <div class="px-12">
          <svg height="28" viewBox="0 0 56 28" fill="none" xmlns="http://www.w3.org/2000/svg" style={`opacity:${opacity}`}>
            <!-- Shield shape -->
            <path d="M4 2 H52 L52 16 Q28 28 28 28 Q28 28 4 16 Z" fill={fill} />
            <text x="28" y="17" font-family="sans-serif" font-size="11" font-weight="900" fill="#0a0a09" text-anchor="middle" letter-spacing="1">NFL</text>
          </svg>
        </div>

        {/* Apple Music */}
        <div class="px-12">
          <svg height="22" viewBox="0 0 148 22" fill="none" xmlns="http://www.w3.org/2000/svg" style={`opacity:${opacity}`}>
            <g fill={fill}>
              <!-- Music note icon -->
              <rect x="3" y="0" width="2.5" height="14" rx="1.2" />
              <rect x="9" y="3" width="2.5" height="11" rx="1.2" />
              <rect x="3" y="0" width="9" height="2.5" rx="1.2" />
              <circle cx="4.25" cy="15.5" r="3.2" />
              <circle cx="10.25" cy="17" r="3.2" />
            </g>
            <text x="22" y="16" font-family="sans-serif" font-size="15" font-weight="600" fill={fill} letter-spacing="0.2">Apple Music</text>
          </svg>
        </div>

        {/* Sony */}
        <div class="px-12">
          <svg height="22" viewBox="0 0 68 22" fill="none" xmlns="http://www.w3.org/2000/svg" style={`opacity:${opacity}`}>
            <text x="0" y="16" font-family="sans-serif" font-size="17" font-weight="700" fill={fill} letter-spacing="3">SONY</text>
          </svg>
        </div>

        {/* Medtronic */}
        <div class="px-12">
          <svg height="22" viewBox="0 0 110 22" fill="none" xmlns="http://www.w3.org/2000/svg" style={`opacity:${opacity}`}>
            <text x="0" y="16" font-family="sans-serif" font-size="15" font-weight="600" fill={fill} letter-spacing="0.3">medtronic</text>
          </svg>
        </div>

        {/* McKinsey & Company */}
        <div class="px-12">
          <svg height="22" viewBox="0 0 200 22" fill="none" xmlns="http://www.w3.org/2000/svg" style={`opacity:${opacity}`}>
            <text x="0" y="16" font-family="sans-serif" font-size="14" font-weight="600" fill={fill} letter-spacing="0.2">McKinsey &amp; Company</text>
          </svg>
        </div>

      </div>
    ))}

  </div>
</section>

<style>
  .marquee-track {
    width: max-content;
    animation: marquee 40s linear infinite;
  }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>
