---
const logos = [
  { src: "/logos/Walmart_Logo_1.png", alt: "Walmart" },
  { src: "/logos/NFL_Symbol_0.svg", alt: "NFL" },
  { src: "/logos/Apple_Music_Logo_1.png", alt: "Apple Music" },
  { src: "/logos/Google_Logo_1.png", alt: "Google" },
  { src: "/logos/Meta_idlf4cVSsS_1.png", alt: "Meta", height: "40px" },
  { src: "/logos/McKinsey___Company_idXaAYJuer_1.png", alt: "McKinsey & Company" },
  { src: "/logos/Medtronic_idOf910Br8_1.png", alt: "Medtronic" },
  { src: "/logos/Samsung_idkTmfps1i_1.png", alt: "Samsung" },
  { src: "/logos/Pfizer_Logo_1.png", alt: "Pfizer" },
];
---

<section class="w-full overflow-hidden border-y border-white/[0.08] py-8">
  <div class="marquee-track flex items-center">

    {[0, 1, 2].map((i) => (
      <div class="flex items-center shrink-0" aria-hidden={i > 0 ? "true" : undefined}>
        {logos.map((logo) => (
          <div class="px-12">
            <img
              src={logo.src}
              alt={logo.alt}
              style={`height:${logo.height ?? "24px"};width:auto;filter:brightness(0) invert(1);opacity:0.5;`}
            />
          </div>
        ))}
      </div>
    ))}

  </div>
</section>

<style>
  .marquee-track {
    width: max-content;
    animation: marquee 40s linear infinite;
  }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>
