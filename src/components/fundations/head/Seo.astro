---
import { AstroSeo } from "@lexingtonthemes/seo";
---

<AstroSeo
  title="Ruth Design Co. — AI Strategy & Product Design"
  description="We fill the design and AI leadership seat your team is missing. Fractional engagement, senior leadership, real execution."
  canonical="https://ruthdesign.ai"
  openGraph={{
    url: "https://ruthdesign.ai",
    title: "Ruth Design Co.",
    description: "We fill the design and AI leadership seat your team is missing. Fractional engagement, senior leadership, real execution.",
    images: [
      {
        url: "https://ruthdesign.ai/og-image.png",
        width: 1200,
        height: 630,
        alt: "Ruth Design Co.",
        type: "image/png",
      },
    ],
    site_name: "Ruth Design Co.",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    handle: "@ruthdesignco",
    site: "@ruthdesignco",
    cardType: "summary_large_image",
  }}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://ruthdesign.ai" />
<meta property="og:title" content="Ruth Design Co." />
<meta property="og:description" content="We fill the design and AI leadership seat your team is missing. Fractional engagement, senior leadership, real execution." />
<meta property="og:image" content="https://ruthdesign.ai/og-image.png" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content="https://ruthdesign.ai" />
<meta name="twitter:title" content="Ruth Design Co." />
<meta name="twitter:description" content="We fill the design and AI leadership seat your team is missing. Fractional engagement, senior leadership, real execution." />
<meta name="twitter:image" content="https://ruthdesign.ai/og-image.png" />

<!-- Canonical URL -->
<link rel="canonical" href="https://ruthdesign.ai" />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
