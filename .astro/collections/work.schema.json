{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "launchDate": {
      "type": "string",
      "format": "date-time"
    },
    "client": {
      "type": "string"
    },
    "work": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "logo": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "alt"
      ],
      "additionalProperties": false
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "launchDate",
    "client",
    "work",
    "description",
    "logo"
  ],
  "additionalProperties": false
}