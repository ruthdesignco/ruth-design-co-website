{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "intro": {
      "type": "string"
    },
    "education": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "avatar": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "alt": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "alt"
      ],
      "additionalProperties": false
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "role",
    "intro",
    "education",
    "experience",
    "avatar"
  ],
  "additionalProperties": false
}